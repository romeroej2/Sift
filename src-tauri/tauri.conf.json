{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SIFT",
  "version": "0.1.1",
  "identifier": "dev.sift.paper",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SIFT",
        "width": 1460,
        "height": 960,
        "minWidth": 1080,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPLOCALDATA/assets/**"]
      },
      "csp": {
        "default-src": "'self' customprotocol: asset: http://asset.localhost",
        "connect-src": "ipc: http://ipc.localhost",
        "img-src": "'self' asset: http://asset.localhost data: blob:",
        "style-src": "'self' 'unsafe-inline' http://asset.localhost"
      },
      "devCsp": {
        "default-src": "'self' customprotocol: asset: http://asset.localhost http://localhost:1420",
        "connect-src": "ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1420",
        "img-src": "'self' asset: http://asset.localhost data: blob: http://localhost:1420",
        "style-src": "'self' 'unsafe-inline' http://localhost:1420",
        "script-src": "'self' 'unsafe-eval' http://localhost:1420"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  }
}
